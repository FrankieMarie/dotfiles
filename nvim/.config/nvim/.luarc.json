{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT"
  },
  "workspace": {
    "library": ["$VIMRUNTIME/lua", "$VIMRUNTIME/lua/vim"],
    "checkThirdParty": false
  },
  "diagnostics": {
    "globals": ["vim"]
  },
  "telemetry": {
    "enable": false
  }
}
